@echo off
:: Кодировка UTF-8, чтобы корректно отображался русский текст
chcp 65001 > nul

:start
cls
echo =======================================
echo          ПРОСТОЙ КАЛЬКУЛЯТОР
echo =======================================
echo.

:: Ввод первого числа
set /p num1="Введите первое число: "

:: Ввод знака операции
echo.
echo Доступные операции: + , - , * , /
set /p op="Выберите операцию: "

:: Ввод второго числа
echo.
set /p num2="Введите второе число: "

:: Проверка деления на ноль
if "%op%"=="/" if "%num2%"=="0" (
    echo.
    echo Ошибка: Деление на ноль невозможно!
    goto retry
)

:: Математическое вычисление
set /a result=%num1% %op% %num2%

echo.
echo ---------------------------------------
echo Результат: %num1% %op% %num2% = %result%
echo ---------------------------------------

:retry
echo.
echo Хотите посчитать что-то еще? (Y - да, N - выйти)
set /p choice="Ваш выбор: "

if /i "%choice%"=="Y" goto start
if /i "%choice%"=="Н" goto start
exit